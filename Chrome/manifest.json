{
  "manifest_version": 3,
  "name": "GitHub Resizer",
  "version": "1.0.0",
  "description": "Widen GitHub pages between the native 1280px default and the full viewport, in 1% steps.",
  "homepage_url": "https://github.com/R0GGER/firefox-github-resize",

  "icons": {
    "16": "icons/icon_32.png",
    "32": "icons/icon_32.png",
    "48": "icons/icon_64.png",
    "128": "icons/icon_128.png"
  },

  "action": {
    "default_title": "GitHub Resizer",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon_32.png",
      "32": "icons/icon_32.png",
      "48": "icons/icon_64.png",
      "128": "icons/icon_128.png"
    }
  },

  "permissions": ["storage"],

  "host_permissions": [
    "*://github.com/*",
    "*://gist.github.com/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "*://github.com/*",
        "*://gist.github.com/*"
      ],
      "js": ["content/content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ]
}
